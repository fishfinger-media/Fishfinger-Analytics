---
// Main dashboard UI — site selector, date range picker, generate button.
// All interactivity lives in the <script> tag below (plain client-side JS).
---

<div class="p-8 max-w-xl">
  <h1 class="text-2xl font-semibold text-slate-800 mb-1">Generate Report</h1>
  <p class="text-sm text-slate-500 mb-8">
    Select a site and date range, then click <strong>Generate PDF</strong> to download your analytics report.
  </p>

  <!-- No sites warning -->
  <div id="no-sites-warning" class="hidden mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800">
    No sites configured. Go to <a href="/settings" class="font-medium underline">Settings</a> to add your Plausible domains.
  </div>

  <!-- Form -->
  <form id="report-form" class="space-y-5">
    <!-- Site selector -->
    <div>
      <label for="site-select" class="block text-sm font-medium text-slate-700 mb-1.5">Site</label>
      <select
        id="site-select"
        class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-slate-800"
      >
        <!-- populated by script -->
      </select>
    </div>

    <!-- Date range -->
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1.5">Date Range</label>
      <div class="flex items-center gap-3">
        <input
          type="date"
          id="date-from"
          class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-slate-800"
        />
        <span class="text-slate-400 text-sm">to</span>
        <input
          type="date"
          id="date-to"
          class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-slate-800"
        />
      </div>
      <!-- Quick presets -->
      <div class="flex gap-2 mt-2 flex-wrap">
        <button type="button" data-preset="7"  class="preset-btn text-xs px-2.5 py-1 rounded-md border border-slate-200 text-slate-500 hover:border-blue-400 hover:text-blue-600 transition-colors bg-white">Last 7 days</button>
        <button type="button" data-preset="28" class="preset-btn text-xs px-2.5 py-1 rounded-md border border-slate-200 text-slate-500 hover:border-blue-400 hover:text-blue-600 transition-colors bg-white">Last 28 days</button>
        <button type="button" data-preset="90" class="preset-btn text-xs px-2.5 py-1 rounded-md border border-slate-200 text-slate-500 hover:border-blue-400 hover:text-blue-600 transition-colors bg-white">Last 90 days</button>
        <button type="button" data-preset="month" class="preset-btn text-xs px-2.5 py-1 rounded-md border border-slate-200 text-slate-500 hover:border-blue-400 hover:text-blue-600 transition-colors bg-white">This month</button>
        <button type="button" data-preset="lastmonth" class="preset-btn text-xs px-2.5 py-1 rounded-md border border-slate-200 text-slate-500 hover:border-blue-400 hover:text-blue-600 transition-colors bg-white">Last month</button>
      </div>
    </div>

    <!-- Generate button -->
    <button
      id="generate-btn"
      type="submit"
      class="w-full py-2.5 px-4 bg-slate-800 text-white text-sm font-medium rounded-lg hover:bg-slate-700 active:bg-slate-900 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Generate PDF
    </button>
  </form>

  <!-- Progress -->
  <div id="progress-area" class="hidden mt-6">
    <div class="flex items-center justify-between mb-1.5">
      <span id="progress-msg" class="text-sm text-slate-600"></span>
      <span id="progress-pct" class="text-sm font-medium text-slate-700">0%</span>
    </div>
    <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
      <div id="progress-bar" class="h-full bg-blue-500 rounded-full transition-all duration-300" style="width:0%"></div>
    </div>
  </div>

  <!-- Error -->
  <div id="error-area" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
</div>

<script>
  const STORAGE_KEY = 'fishfinger_sites';

  // ── Populate site dropdown from localStorage ────────────────────────────────
  const sites: string[] = (() => {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]'); }
    catch { return []; }
  })();

  const select = document.getElementById('site-select') as HTMLSelectElement;
  const noSitesWarning = document.getElementById('no-sites-warning')!;

  if (sites.length === 0) {
    noSitesWarning.classList.remove('hidden');
    select.disabled = true;
  } else {
    sites.forEach((s) => {
      const opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      select.appendChild(opt);
    });
  }

  // ── Default date range ─────────────────────────────────────────────────────
  function toDateStr(d: Date): string {
    return d.toISOString().slice(0, 10);
  }

  function setDefaultRange(): void {
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    // Default: last day of previous month → today (UTC-ish, via ISO string).
    // This avoids confusing month-month labels in the PDF header.
    const from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 0));
    const fromInput = document.getElementById('date-from') as HTMLInputElement;
    const toInput = document.getElementById('date-to') as HTMLInputElement;
    fromInput.value = toDateStr(from);
    toInput.value = toDateStr(now);
  }

  function setPreset(days: number | 'month' | 'lastmonth'): void {
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const fromInput = document.getElementById('date-from') as HTMLInputElement;
    const toInput = document.getElementById('date-to') as HTMLInputElement;

    if (days === 'month') {
      const from = new Date(today.getFullYear(), today.getMonth(), 1);
      fromInput.value = toDateStr(from);
      toInput.value = toDateStr(today);
    } else if (days === 'lastmonth') {
      const from = new Date(today.getFullYear(), today.getMonth() - 1, 1);
      const to = new Date(today.getFullYear(), today.getMonth(), 0);
      fromInput.value = toDateStr(from);
      toInput.value = toDateStr(to);
    } else {
      const from = new Date(today);
      from.setDate(today.getDate() - (days - 1));
      fromInput.value = toDateStr(from);
      toInput.value = toDateStr(today);
    }
  }

  // Default: last day of previous month → today
  setDefaultRange();

  // Preset buttons
  document.querySelectorAll<HTMLButtonElement>('.preset-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const preset = btn.dataset.preset!;
      if (preset === 'month' || preset === 'lastmonth') {
        setPreset(preset);
      } else {
        setPreset(parseInt(preset, 10));
      }
    });
  });

  // ── Progress helpers ────────────────────────────────────────────────────────
  const progressArea = document.getElementById('progress-area')!;
  const progressMsg = document.getElementById('progress-msg')!;
  const progressPct = document.getElementById('progress-pct')!;
  const progressBar = document.getElementById('progress-bar') as HTMLElement;
  const errorArea = document.getElementById('error-area')!;
  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;

  function showProgress(msg: string, pct: number): void {
    progressArea.classList.remove('hidden');
    errorArea.classList.add('hidden');
    progressMsg.textContent = msg;
    progressPct.textContent = `${pct}%`;
    progressBar.style.width = `${pct}%`;
  }

  function showError(msg: string): void {
    errorArea.textContent = msg;
    errorArea.classList.remove('hidden');
    progressArea.classList.add('hidden');
  }

  function resetUI(): void {
    generateBtn.disabled = false;
    generateBtn.textContent = 'Generate PDF';
  }

  // ── Form submit ─────────────────────────────────────────────────────────────
  document.getElementById('report-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();

    const siteId = select.value;
    const dateFrom = (document.getElementById('date-from') as HTMLInputElement).value;
    const dateTo = (document.getElementById('date-to') as HTMLInputElement).value;

    if (!siteId) {
      showError('Please add a site in Settings first.');
      return;
    }
    if (!dateFrom || !dateTo) {
      showError('Please select a date range.');
      return;
    }
    if (dateFrom > dateTo) {
      showError('"From" date must be before "To" date.');
      return;
    }

    generateBtn.disabled = true;
    generateBtn.textContent = 'Generating…';
    showProgress('Starting…', 0);

    try {
      const { generatePDF } = await import('../lib/pdf/generator');
      const dateRange = `${dateFrom},${dateTo}`;
      await generatePDF(siteId, dateRange, dateFrom, dateTo, showProgress);
    } catch (err: unknown) {
      const msg = err instanceof Error ? err.message : 'An unexpected error occurred.';
      showError(`Error: ${msg}`);
    } finally {
      resetUI();
    }
  });
</script>
