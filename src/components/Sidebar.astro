        <path d="m18.658 9.6651v-6.3297c0-1.8381-1.7047-3.3353-3.8097-3.3353h-7.5601c-2.105 0-3.8097 1.4972-3.8097 3.3353v6.1074c-0.96354 1.097-4.2099 5.0252-3.0982 7.5305 0.44471 1.0376 1.4972 1.6306 3.0982 1.764v8.4791c0 1.8382 1.7047 3.3354 3.8097 3.3354h1.0228c-1.1859 1.3341-2.7276 3.4836-2.0901 5.04 0.38542 0.9339 1.3934 1.4083 3.0092 1.4083h0.23718l0.3706-0.0148 1.1118-1.2156 0.1186 0.1186 0.252 0.2372 0.9042 0.8598 0.341 0.0148h0.2372c1.6306 0 2.6682-0.4744 3.0685-1.4083 0.6522-1.5564-0.9191-3.7059-2.1198-5.04h1.1117c2.105 0 3.8097-1.4972 3.8097-3.3354v-8.5088c1.4972-0.163 2.4756-0.756 2.9055-1.7492 1.008-2.3421-1.7789-5.9591-2.9203-7.2932zm-15.179 7.3229c-0.63742-0.0741-1.3193-0.252-1.512-0.7116-0.35577-0.8301 0.47436-2.5052 1.512-4.0172v4.7288zm10.732 17.937c-0.0445 0.1186-0.3854 0.3113-1.2897 0.3409l-0.7263-0.6819-1.2156-1.423-1.927 2.1049c-0.85978-0.0148-1.1859-0.2223-1.2304-0.3409-0.23718-0.5633 1.008-2.5052 2.5941-4.0469l0.3262-0.3113h0.4743l0.3261 0.3113c1.6455 1.5417 2.9203 3.4688 2.6683 4.0469zm2.6831-7.6935c0 0.8746-0.9191 1.5861-2.0457 1.5861h-7.5601c-1.1266 0-2.0457-0.7115-2.0457-1.5861v-0.7709c0.38542 0.2076 0.81531 0.3262 1.2897 0.3262 0.93389 0 1.7492-0.4744 2.2236-1.2008 0.47436 0.7264 1.2896 1.2008 2.2235 1.2008s1.7492-0.4744 2.2236-1.2008c0.4744 0.7264 1.2897 1.2008 2.2235 1.2008 0.5485 0 1.0674-0.1631 1.4824-0.4596v0.9043h-0.0148zm0-2.1198c-0.3261 0.4743-0.8746 0.8005-1.4824 0.8005-0.9487 0-1.7195-0.7412-1.7788-1.6751v-0.1186h-0.8894v0.1186c-0.0593 0.9339-0.845 1.6751-1.7789 1.6751-0.9487 0-1.7344-0.7412-1.7788-1.6751v-0.1038h-0.88942v0.1186c-0.05929 0.9339-0.83013 1.6751-1.7788 1.6751-0.504 0-0.96354-0.2076-1.2897-0.5485v-4.6843c0.38542 0.2075 0.8153 0.341 1.2897 0.341 0.9339 0 1.7492-0.4744 2.2236-1.2008 0.47436 0.7264 1.2896 1.2008 2.2236 1.2008s1.7492-0.4744 2.2236-1.2008c0.4743 0.7264 1.2896 1.2008 2.2235 1.2008 0.5485 0 1.0673-0.1631 1.4824-0.4596v4.5361zm0-5.7813c-0.3261 0.4744-0.8746 0.8005-1.4824 0.8005-0.9487 0-1.7195-0.7412-1.778