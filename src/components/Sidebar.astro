---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isSettings = pathname.startsWith('/settings');
const isPdfPreview = pathname.startsWith('/pdf-preview');

interface Props {
  pageTitle?: string;
  pageDescription?: string;
}

const { pageTitle, pageDescription } = Astro.props;
---

<aside class="shrink-0 p-4 sticky top-0 h-screen">
  <div
    class="h-full w-full rounded-2xl bg-gradient-to-b from-[#fa921f] to-[#f67517] text-white flex flex-col items-center py-6 px-2"
    style="width: 84px;"
  >
    <div class="w-10 mb-6">
