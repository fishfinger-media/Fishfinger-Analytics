---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isSettings = pathname.startsWith('/settings');
---

<nav class="w-14 flex flex-col items-center py-6 gap-4 border-r border-slate-200 bg-white shrink-0">
  <!-- Logo / brand mark -->
  <div class="w-8 h-8 rounded-lg bg-slate-800 flex items-center justify-center mb-4">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="1" y="8" width="3" height="7" rx="1" fill="white"/>
      <rect x="6" y="5" width="3" height="10" rx="1" fill="white"/>
      <rect x="11" y="2" width="3" height="13" rx="1" fill="white"/>
    </svg>
  </div>

  <!-- Home -->
  <a
    href="/"
    title="Home"
    class={`w-10 h-10 rounded-lg flex items-center justify-center transition-colors ${
      isHome
        ? 'bg-blue-50 text-blue-600'
        : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'
    }`}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
      <polyline points="9 21 9 12 15 12 15 21"/>
    </svg>
  </a>

  <!-- Settings -->
  <a
    href="/settings"
    title="Settings"
    class={`w-10 h-10 rounded-lg flex items-center justify-center transition-colors ${
      isSettings
        ? 'bg-blue-50 text-blue-600'
        : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'
    }`}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
  </a>
</nav>
