      </svg>
    </div>

    <nav class="flex flex-col items-center gap-4 w-full">
      <a
        href="/"
        title="Home"
        aria-current={isHome ? 'page' : undefined}
        class={`w-[70%] aspect-square rounded-[10px] flex items-center justify-center transition-colors ${
          isHome ? 'bg-[#f67517]' : 'hover:bg-[#f67517]'
        }`}
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"></path>
          <polyline points="9 21 9 12 15 12 15 21"></polyline>
        </svg>
      </a>

      <a
        href="/pdf-preview"
        title="Preview"
        aria-current={isPdfPreview ? 'page' : undefined}
        class={`w-[70%] aspect-square rounded-[10px] flex items-center justify-center transition-colors ${
          isPdfPreview ? 'bg-[#f67517]' : 'hover:bg-[#f67517]'
        }`}
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="8" y1="13" x2="16" y2="13"></line>
          <line x1="8" y1="17" x2="14" y2="17"></line>
        </svg>
      </a>
    </nav>

    <a
      href="/settings"
      title="Settings"
      aria-current={isSettings ? 'page' : undefined}
      class="w-[70%] aspect-square rounded-[10px] flex items-center justify-center transition-colors bg-[#0b88c9] hover:bg-[#0678b2] mt-auto"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
    </a>

  <script>
    const LAST_REPORT_KEY = 'fishfinger_last_report';

    function fmtMonthYear(dateStr) {
      if (!dateStr) return null;
      const d = new Date(dateStr + 'T00:00:00');
      if (Number.isNaN(d.getTime())) return null;
      return d.toLocaleString(undefined, { month: 'short', year: 'numeric' });
    }

    try {
      const elSite = document.getElementById('sidebar-site-name');
      const elRange = document.getElementById('sidebar-date-range');
      const raw = localStorage.getItem(LAST_REPORT_KEY);
      const data = raw ? JSON.parse(raw) : null;

      if (data?.siteId && elSite) elSite.textContent = data.siteId;

      const from = fmtMonthYear(data?.dateFrom);
      const to = fmtMonthYear(data?.dateTo);
      if (from && to && elRange) elRange.textContent = `${from} – ${to}`;
    } catch {}
  </script>
</aside>
