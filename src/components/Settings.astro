---
// Settings component — manages the list of Plausible site domains.
// Site list is stored in localStorage so it persists across sessions.
---

<div class="p-8 max-w-lg">
  <h1 class="text-2xl font-semibold text-slate-800 mb-1">Settings</h1>
  <p class="text-slate-500 text-sm mb-8">Configure Slack, test messages/PDFs, and manage automations.</p>

  <div class="mb-6 border-b border-slate-200">
    <div class="flex items-center gap-2 overflow-x-auto" role="tablist" aria-label="Settings sections">
      <button
        type="button"
        class="settings-tab px-3 py-2 text-sm font-medium rounded-t-lg border border-slate-200 border-b-0 bg-white text-slate-900"
        data-tab="sites"
        role="tab"
        aria-selected="true"
        aria-controls="panel-sites"
        id="tab-sites"
      >
        Sites
      </button>
      <button
        type="button"
        class="settings-tab px-3 py-2 text-sm font-medium rounded-t-lg text-slate-600 hover:text-slate-900"
        data-tab="slack"
        role="tab"
        aria-selected="false"
        aria-controls="panel-slack"
        id="tab-slack"
      >
        Slack + Test message
      </button>
      <button
        type="button"
        class="settings-tab px-3 py-2 text-sm font-medium rounded-t-lg text-slate-600 hover:text-slate-900"
        data-tab="pdfs"
        role="tab"
        aria-selected="false"
        aria-controls="panel-pdfs"
        id="tab-pdfs"
      >
        Test PDFs
      </button>
      <button
        type="button"
        class="settings-tab px-3 py-2 text-sm font-medium rounded-t-lg text-slate-600 hover:text-slate-900"
        data-tab="automations"
        role="tab"
        aria-selected="false"
        aria-controls="panel-automations"
        id="tab-automations"
      >
        Automations
      </button>
    </div>
  </div>

  <section id="panel-sites" role="tabpanel" aria-labelledby="tab-sites" data-panel="sites">
    <div class="mb-6">
      <h2 class="text-xs font-semibold uppercase text-slate-400 mb-3">Sites</h2>
      <ul id="site-list" class="space-y-2">
        <!-- populated by script -->
      </ul>
      <p id="empty-msg" class="text-sm text-slate-400 italic hidden">No sites added yet.</p>
    </div>

    <form id="add-site-form" class="flex gap-2">
      <input
        id="new-site-input"
        type="text"
        placeholder="example.com"
        autocomplete="off"
        spellcheck="false"
        class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent placeholder-slate-400"
      />
      <button
        type="submit"
        class="px-4 py-2 text-sm font-medium bg-slate-800 text-white rounded-lg hover:bg-slate-700 transition-colors"
      >
        Add site
      </button>
    </form>
    <p id="form-error" class="mt-2 text-sm text-red-500 hidden"></p>
  </section>

  <section id="panel-slack" role="tabpanel" aria-labelledby="tab-slack" data-panel="slack" class="hidden">
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase text-slate-400 mb-3">Slack</h2>
      <div class="flex items-center gap-3">
        <a
          id="connect-slack"
          href="/api/slack/oauth/start?returnTo=%2Fsettings"
          class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-500 transition-colors"
        >
          Connect Slack
        </a>
        <span id="slack-status" class="text-sm text-slate-500">Checking…</span>
      </div>
      <p class="text-xs text-slate-400 mt-2">
        For local dev, Slack OAuth requires a public URL. Use a tunnel (e.g. Cloudflare Tunnel / ngrok) and set
        <span class="font-mono">APP_BASE_URL</span>.
      </p>

      <div class="mt-4 p-3 bg-slate-50 border border-slate-200 rounded-lg space-y-2">
        <div class="text-xs font-semibold uppercase text-slate-400">Send test text message</div>
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500 w-16">Channel</label>
          <select
            id="slack-test-channel"
            class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            disabled
          >
            <option value="">Connect Slack to pick a channel</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500 w-16">Text</label>
          <input
            id="slack-test-text"
            type="text"
            class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent placeholder-slate-400"
            placeholder="Type any message…"
            disabled
          />
          <button
            id="slack-test-send"
            type="button"
            class="px-3 py-2 text-xs font-medium bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors disabled:opacity-50"
            disabled
          >
            Send
          </button>
        </div>
        <div id="slack-test-status" class="text-xs text-slate-400"></div>
        <div class="text-xs text-slate-400">
          If you see <span class="font-mono">not_in_channel</span>, invite the bot to the channel:
          <span class="font-mono">/invite @YourAppName</span>
        </div>
      </div>
    </div>
  </section>

  <section id="panel-pdfs" role="tabpanel" aria-labelledby="tab-pdfs" data-panel="pdfs" class="hidden">
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase text-slate-400 mb-3">Test PDFs</h2>
      <div class="p-3 bg-slate-50 border border-slate-200 rounded-lg space-y-2">
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500 w-16">Website</label>
          <select
            id="pdf-test-site"
            class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >
            <option value="">Select a website…</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500 w-16">Channel</label>
          <select
            id="pdf-test-channel"
            class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            disabled
          >
            <option value="">Connect Slack to pick a channel</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <button
            id="pdf-test-send"
            type="button"
            class="px-3 py-2 text-xs font-medium bg-slate-800 text-white rounded-lg hover:bg-slate-700 transition-colors disabled:opacity-50"
            disabled
          >
            Send test PDF
          </button>
          <span id="pdf-test-status" class="text-xs text-slate-400"></span>
        </div>
        <div class="text-xs text-slate-400">Default range: last day of previous month → today.</div>
      </div>
    </div>
  </section>

  <section id="panel-automations" role="tabpanel" aria-labelledby="tab-automations" data-panel="automations" class="hidden">
    <div class="mt-2">
      <h2 class="text-xs font-semibold uppercase text-slate-400 mb-3">Automations</h2>
      <div class="p-3 bg-slate-50 border border-slate-200 rounded-lg space-y-3">
        <div class="text-xs text-slate-400">
          Create an automation by choosing a website, Slack channel, and the next run date+time.
        </div>

        <div class="grid grid-cols-4 gap-2 items-center">
          <div class="text-xs text-slate-500 col-span-1">Website</div>
          <select
            id="auto-create-site"
            class="col-span-3 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >
            <option value="">Select a website…</option>
          </select>
        </div>

        <div class="grid grid-cols-4 gap-2 items-center">
          <div class="text-xs text-slate-500 col-span-1">Channel</div>
          <select
            id="auto-create-channel"
            class="col-span-3 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            disabled
          >
            <option value="">Connect Slack to pick a channel</option>
          </select>
        </div>

        <div class="grid grid-cols-4 gap-2 items-center">
          <div class="text-xs text-slate-500 col-span-1">Run at</div>
          <input
            id="auto-create-datetime"
            type="datetime-local"
            class="col-span-2 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
          <button
            id="auto-create-save"
            type="button"
            class="col-span-1 px-3 py-2 text-xs font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-500 transition-colors disabled:opacity-50"
            disabled
          >
            Save
          </button>
        </div>
        <div id="auto-create-status" class="text-xs text-slate-400"></div>
      </div>

      <ul id="automation-list" class="mt-4 space-y-2">
        <!-- populated by script -->
      </ul>
    </div>
  </section>
</div>

<script>
  const STORAGE_KEY = 'fishfinger_sites';
  const SETTINGS_TAB_KEY = 'fishfinger_settings_active_tab';

  function setActiveSettingsTab(tab: string): void {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.settings-tab'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));

    for (const t of tabs) {
      const on = t.dataset.tab === tab;
      t.setAttribute('aria-selected', on ? 'true' : 'false');
      t.tabIndex = on ? 0 : -1;
      t.classList.toggle('bg-white', on);
      t.classList.toggle('border', on);
      t.classList.toggle('border-slate-200', on);
      t.classList.toggle('border-b-0', on);
      t.classList.toggle('text-slate-900', on);
      t.classList.toggle('text-slate-600', !on);
    }

    for (const p of panels) {
      p.classList.toggle('hidden', p.dataset.panel !== tab);
    }

    try {
      localStorage.setItem(SETTINGS_TAB_KEY, tab);
    } catch {
      // ignore
    }
  }

  function initSettingsTabs(): void {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.settings-tab'));
    if (tabs.length === 0) return;

    let initial = 'sites';
    const hash = (location.hash || '').replace(/^#/, '');
    if (hash && tabs.some((t) => t.dataset.tab === hash)) initial = hash;
    else {
      try {
        const saved = localStorage.getItem(SETTINGS_TAB_KEY);
        if (saved && tabs.some((t) => t.dataset.tab === saved)) initial = saved;
      } catch {
        // ignore
      }
    }

    for (const t of tabs) {
      t.addEventListener('click', () => {
        const tab = t.dataset.tab;
        if (!tab) return;
        setActiveSettingsTab(tab);
        history.replaceState(null, '', `#${tab}`);
      });
    }

    setActiveSettingsTab(initial);
  }

  async function fetchSlackStatus(): Promise<{ connected: boolean; teamId: string | null }> {
    const res = await fetch('/api/slack/status', { cache: 'no-store' });
    if (!res.ok) return { connected: false, teamId: null };
    return await res.json();
  }

  async function fetchChannels(): Promise<Array<{ id: string; name: string }>> {
    const res = await fetch('/api/slack/channels', { cache: 'no-store' });
    if (!res.ok) return [];
    const json = await res.json();
    return json.channels ?? [];
  }

  function getSites(): string[] {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]');
    } catch {
      return [];
    }
  }

  function saveSites(sites: string[]): void {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(sites));
  }

  type SiteTarget = {
    channelId: string;
    enabled: boolean;
    schedule?: { timeZone: string; runAt: string };
  };

  async function fetchTargets(): Promise<Record<string, SiteTarget>> {
    const res = await fetch('/api/automation/targets', { cache: 'no-store' });
    if (!res.ok) return {};
    const j = await res.json().catch(() => ({}));
    return j.targets ?? {};
  }

  async function saveTarget(siteId: string, target: SiteTarget): Promise<void> {
    const res = await fetch('/api/automation/targets', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ siteId, target }),
    });
    const j = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(j.detail || j.error || 'Failed to save automation');
  }

  function renderSites(): void {
    const sites = getSites();
    const list = document.getElementById('site-list')!;
    const emptyMsg = document.getElementById('empty-msg')!;

    if (sites.length === 0) {
      list.innerHTML = '';
      emptyMsg.classList.remove('hidden');
      return;
    }

    emptyMsg.classList.add('hidden');
    list.innerHTML = sites
      .map(
        (s, i) => `
          <li class="px-3 py-3 bg-white border border-slate-200 rounded-lg space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-700 font-mono">${s}</span>
              <button
                data-index="${i}"
                class="remove-btn text-slate-400 hover:text-red-500 transition-colors ml-4"
                title="Remove ${s}"
                aria-label="Remove ${s}"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                  <path d="M10 11v6M14 11v6"/>
                  <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                </svg>
              </button>
            </div>
          </li>
        `
      )
      .join('');

    list.querySelectorAll<HTMLButtonElement>('.remove-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.index);
        const updated = getSites().filter((_, i) => i !== idx);
        saveSites(updated);
        renderSites();
        renderAutomationUI();
        renderTestPdfUI();
      });
    });
  }

  function renderTestPdfUI(): void {
    const sites = getSites();
    const siteSelect = document.getElementById('pdf-test-site') as HTMLSelectElement | null;
    if (!siteSelect) return;
    const current = siteSelect.value;
    siteSelect.innerHTML =
      `<option value="">Select a website…</option>` + sites.map((s) => `<option value="${s}">${s}</option>`).join('');
    if (current && sites.includes(current)) siteSelect.value = current;
  }

  function toDatetimeLocalValue(iso: string): string {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    const pad = (n: number) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  function renderAutomationUI(targets: Record<string, SiteTarget> = {}): void {
    const sites = getSites();

    const createSite = document.getElementById('auto-create-site') as HTMLSelectElement | null;
    if (createSite) {
      const cur = createSite.value;
      createSite.innerHTML =
        `<option value="">Select a website…</option>` + sites.map((s) => `<option value="${s}">${s}</option>`).join('');
      if (cur && sites.includes(cur)) createSite.value = cur;
    }

    const list = document.getElementById('automation-list') as HTMLUListElement | null;
    if (!list) return;

    const withTargets = sites.map((siteId) => ({ siteId, target: targets?.[siteId] })).filter((x) => x.target);
    if (withTargets.length === 0) {
      list.innerHTML = `<li class="text-sm text-slate-400 italic">No automations configured yet.</li>`;
      return;
    }

    list.innerHTML = withTargets
      .map(({ siteId, target }) => {
        const enabled = Boolean(target?.enabled);
        const tz = target?.schedule?.timeZone || Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
        const runAt = target?.schedule?.runAt ? toDatetimeLocalValue(target.schedule.runAt) : '';

        return `
          <li class="px-3 py-3 bg-white border border-slate-200 rounded-lg space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-700 font-mono">${siteId}</span>
              <div class="flex items-center gap-2">
                <button
                  type="button"
                  class="auto-delete text-xs text-red-600 hover:text-red-700"
                  data-site="${siteId}"
                  title="Delete automation"
                >
                  Delete
                </button>
                <span class="auto-status text-xs text-slate-400" data-site="${siteId}"></span>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <label class="text-xs text-slate-500 w-16">Enabled</label>
              <input type="checkbox" class="auto-enabled" data-site="${siteId}" ${enabled ? 'checked' : ''} />
            </div>

            <div class="flex items-center gap-2">
              <label class="text-xs text-slate-500 w-16">Channel</label>
              <select
                data-site="${siteId}"
                class="auto-channel flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                disabled
              >
                <option value="">Connect Slack to pick a channel</option>
              </select>
            </div>

            <div class="grid grid-cols-4 gap-2 items-center">
              <div class="text-xs text-slate-500 col-span-1">Run at</div>
              <input
                data-site="${siteId}"
                type="datetime-local"
                class="auto-runAt col-span-2 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                value="${runAt}"
                ${enabled ? '' : 'disabled'}
              />
              <input
                data-site="${siteId}"
                class="auto-tz col-span-1 px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                value="${tz}"
                placeholder="Europe/London"
                ${enabled ? '' : 'disabled'}
              />
            </div>
          </li>
        `;
      })
      .join('');

    list.querySelectorAll<HTMLButtonElement>('.auto-delete').forEach((btn) => {
      btn.onclick = async () => {
        const siteId = btn.dataset.site;
        if (!siteId) return;
        btn.disabled = true;
        try {
          const res = await fetch('/api/automation/targets', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ siteId }),
          });
          const j = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(j.detail || j.error || 'Failed');
          const refreshed = await fetchTargets();
          renderAutomationUI(refreshed);
          // If Slack is connected, channel options + handlers need re-hydration.
          const { connected } = await fetchSlackStatus();
          if (connected) {
            const channels = await fetchChannels();
            await hydrateAutomationControls({ channels, targets: refreshed });
          }
        } catch (err) {
          const status = document.querySelector<HTMLSpanElement>(`.auto-status[data-site="${siteId}"]`);
          if (status) status.textContent = `Error: ${String(err)}`;
        } finally {
          btn.disabled = false;
        }
      };
    });
  }

  async function initSlackUI(): Promise<void> {
    const statusEl = document.getElementById('slack-status')!;
    const { connected, teamId } = await fetchSlackStatus();
    statusEl.textContent = connected ? `Connected${teamId ? ` (${teamId})` : ''}` : 'Not connected';

    const targets = await fetchTargets();
    renderAutomationUI(targets);
    renderTestPdfUI();

    if (!connected) return;

    const channels = await fetchChannels();

    const slackTestChannel = document.getElementById('slack-test-channel') as HTMLSelectElement | null;
    const slackTestText = document.getElementById('slack-test-text') as HTMLInputElement | null;
    const slackTestSend = document.getElementById('slack-test-send') as HTMLButtonElement | null;
    const slackTestStatus = document.getElementById('slack-test-status') as HTMLDivElement | null;

    if (slackTestChannel) {
      slackTestChannel.disabled = false;
      slackTestChannel.innerHTML =
        `<option value="">Select a channel…</option>` + channels.map((c) => `<option value="${c.id}">#${c.name}</option>`).join('');
    }
    if (slackTestText) slackTestText.disabled = false;
    if (slackTestSend) slackTestSend.disabled = false;
    if (slackTestSend) {
      slackTestSend.onclick = async () => {
        const channelId = slackTestChannel?.value;
        const text = slackTestText?.value?.trim();
        if (!channelId) {
          if (slackTestStatus) slackTestStatus.textContent = 'Pick a channel first';
          return;
        }
        if (!text) {
          if (slackTestStatus) slackTestStatus.textContent = 'Type a message first';
          return;
        }
        if (slackTestStatus) slackTestStatus.textContent = 'Sending…';
        slackTestSend.disabled = true;
        try {
          const res = await fetch('/api/test/send-message-to-slack', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ channelId, text }),
          });
          const j = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(j.detail || j.error || 'Failed');
          if (slackTestStatus) slackTestStatus.textContent = 'Sent';
        } catch (err) {
          if (slackTestStatus) slackTestStatus.textContent = `Error: ${String(err)}`;
        } finally {
          slackTestSend.disabled = false;
        }
      };
    }

    const pdfChannel = document.getElementById('pdf-test-channel') as HTMLSelectElement | null;
    const pdfSite = document.getElementById('pdf-test-site') as HTMLSelectElement | null;
    const pdfSend = document.getElementById('pdf-test-send') as HTMLButtonElement | null;
    const pdfStatus = document.getElementById('pdf-test-status') as HTMLSpanElement | null;

    if (pdfChannel) {
      pdfChannel.disabled = false;
      pdfChannel.innerHTML =
        `<option value="">Select a channel…</option>` + channels.map((c) => `<option value="${c.id}">#${c.name}</option>`).join('');
    }
    if (pdfSend) pdfSend.disabled = false;

    if (pdfSend) {
      pdfSend.onclick = async () => {
      const siteId = pdfSite?.value?.trim();
      const channelId = pdfChannel?.value?.trim();
      if (!siteId) {
        if (pdfStatus) pdfStatus.textContent = 'Pick a website first';
        return;
      }
      if (!channelId) {
        if (pdfStatus) pdfStatus.textContent = 'Pick a channel first';
        return;
      }

      if (pdfStatus) pdfStatus.textContent = 'Generating…';
      if (pdfSend) pdfSend.disabled = true;
      try {
        const now = new Date();
        const dateTo = now.toISOString().slice(0, 10); // UTC day
        // Default: last day of previous month → today (UTC), matching automation behavior.
        const from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 0));
        const dateFrom = from.toISOString().slice(0, 10);

        const res = await fetch('/api/test/send-pdf-to-slack', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ siteId, channelId, dateFrom, dateTo }),
        });
        const j = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(j.detail || j.error || 'Failed');
        if (pdfStatus) pdfStatus.textContent = 'Sent';
      } catch (err) {
        if (pdfStatus) pdfStatus.textContent = `Error: ${String(err)}`;
      } finally {
        if (pdfSend) pdfSend.disabled = false;
      }
      };
    }

    const createChannel = document.getElementById('auto-create-channel') as HTMLSelectElement | null;
    const createSite = document.getElementById('auto-create-site') as HTMLSelectElement | null;
    const createDatetime = document.getElementById('auto-create-datetime') as HTMLInputElement | null;
    const createSave = document.getElementById('auto-create-save') as HTMLButtonElement | null;
    const createStatus = document.getElementById('auto-create-status') as HTMLDivElement | null;

    if (createChannel) {
      createChannel.disabled = false;
      createChannel.innerHTML =
        `<option value="">Select a channel…</option>` + channels.map((c) => `<option value="${c.id}">#${c.name}</option>`).join('');
    }
    if (createSave) createSave.disabled = false;

    if (createSave) {
      createSave.onclick = async () => {
      const siteId = createSite?.value?.trim();
      const channelId = createChannel?.value?.trim();
      const dt = createDatetime?.value?.trim();
      if (!siteId) {
        if (createStatus) createStatus.textContent = 'Pick a website first';
        return;
      }
      if (!channelId) {
        if (createStatus) createStatus.textContent = 'Pick a channel first';
        return;
      }
      if (!dt) {
        if (createStatus) createStatus.textContent = 'Pick a date+time first';
        return;
      }

      const runAt = new Date(dt);
      if (Number.isNaN(runAt.getTime())) {
        if (createStatus) createStatus.textContent = 'Invalid date+time';
        return;
      }

      const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';

      if (createStatus) createStatus.textContent = 'Saving…';
      if (createSave) createSave.disabled = true;
      try {
        await saveTarget(siteId, { enabled: true, channelId, schedule: { timeZone, runAt: runAt.toISOString() } });
        if (createStatus) createStatus.textContent = 'Saved';
        const refreshed = await fetchTargets();
        renderAutomationUI(refreshed);
        await hydrateAutomationControls({ channels, targets: refreshed });
      } catch (err) {
        if (createStatus) createStatus.textContent = `Error: ${String(err)}`;
      } finally {
        if (createSave) createSave.disabled = false;
      }
      };
    }

    await hydrateAutomationControls({ channels, targets });
  }

  async function hydrateAutomationControls(params: {
    channels: Array<{ id: string; name: string }>;
    targets: Record<string, SiteTarget>;
  }): Promise<void> {
    const { channels, targets } = params;

    const selects = Array.from(document.querySelectorAll<HTMLSelectElement>('.auto-channel'));
    for (const sel of selects) {
      sel.disabled = false;
      sel.innerHTML =
        `<option value="">Select a channel…</option>` + channels.map((c) => `<option value="${c.id}">#${c.name}</option>`).join('');
      const site = sel.dataset.site;
      if (!site) continue;
      const saved = targets?.[site]?.channelId;
      if (saved) sel.value = saved;
    }

    for (const site of getSites()) {
      const enabledEl = document.querySelector<HTMLInputElement>(`.auto-enabled[data-site="${site}"]`);
      const sel = document.querySelector<HTMLSelectElement>(`.auto-channel[data-site="${site}"]`);
      const tzEl = document.querySelector<HTMLInputElement>(`.auto-tz[data-site="${site}"]`);
      const runEl = document.querySelector<HTMLInputElement>(`.auto-runAt[data-site="${site}"]`);
      const status = document.querySelector<HTMLSpanElement>(`.auto-status[data-site="${site}"]`);
      if (!enabledEl || !sel) continue;

      const current = targets?.[site];
      if (current?.channelId) sel.value = current.channelId;
      if (tzEl) tzEl.value = current?.schedule?.timeZone || tzEl.value || Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      if (runEl && current?.schedule?.runAt) runEl.value = toDatetimeLocalValue(current.schedule.runAt);

      async function persist(): Promise<void> {
        const enabled = Boolean(enabledEl?.checked);
        const channelId = (sel?.value || '').trim();
        const timeZone = (tzEl?.value || '').trim() || (Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC');
        const dt = (runEl?.value || '').trim();
        const runAt = dt ? new Date(dt) : null;

        if (status) status.textContent = 'Saving…';
        try {
          await saveTarget(site, {
            enabled,
            channelId,
            schedule: runAt && !Number.isNaN(runAt.getTime()) ? { timeZone, runAt: runAt.toISOString() } : undefined,
          });
          if (status) status.textContent = 'Saved';
        } catch (err) {
          if (status) status.textContent = `Error: ${String(err)}`;
        }
      }

      enabledEl.addEventListener('change', () => {
        const on = Boolean(enabledEl.checked);
        if (runEl) runEl.disabled = !on;
        if (tzEl) tzEl.disabled = !on;
        void persist();
      });
      sel.addEventListener('change', () => void persist());
      tzEl?.addEventListener('change', () => void persist());
      runEl?.addEventListener('change', () => void persist());
    }
  }

  document.getElementById('add-site-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('new-site-input') as HTMLInputElement;
    const errorEl = document.getElementById('form-error')!;
    const raw = input.value.trim().toLowerCase();

    // Strip protocol if someone pastes a URL
    const domain = raw.replace(/^https?:\/\//, '').replace(/\/.*$/, '');

    if (!domain) {
      errorEl.textContent = 'Please enter a domain name.';
      errorEl.classList.remove('hidden');
      return;
    }

    const sites = getSites();
    if (sites.includes(domain)) {
      errorEl.textContent = `${domain} is already in the list.`;
      errorEl.classList.remove('hidden');
      return;
    }

    errorEl.classList.add('hidden');
    saveSites([...sites, domain]);
    input.value = '';
    renderSites();
    renderAutomationUI();
    renderTestPdfUI();
    void initSlackUI();
  });

  // Clear error on input change
  document.getElementById('new-site-input')!.addEventListener('input', () => {
    document.getElementById('form-error')!.classList.add('hidden');
  });

  renderSites();
  renderAutomationUI();
  renderTestPdfUI();
  initSettingsTabs();
  void initSlackUI();
</script>
