---
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Fishfinger Analytics' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Plausible Analytics PDF report generator" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex min-h-screen bg-slate-100 text-slate-800">
    <Sidebar />
    <main class="flex-1 overflow-auto">
      <slot />
    </main>
  </body>
</html>
